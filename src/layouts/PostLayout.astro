---
import BaseHead from '@/components/BaseHead.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import PostMeta from '@/components/PostMeta.astro';
import TableOfContents from '@/components/TableOfContents.astro';
import SeriesNav from '@/components/SeriesNav.astro';
import PostFooter from '@/components/PostFooter.astro';
import { SITE_NAME } from '@/consts';
import '@/styles/prose.css';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}
interface SeriesItem {
  slug: string;
  title: string;
}
interface Props {
  slug: string;
  title: string;
  description?: string;
  pubDate: Date;
  updatedDate?: Date;
  tags: string[];
  series?: string;
  seriesItems?: SeriesItem[];
  minutesRead?: number;
  heroImage?: string;
  headings: Heading[];
  prevPost?: { slug: string; title: string } | null;
  nextPost?: { slug: string; title: string } | null;
}

const {
  slug,
  title,
  description,
  pubDate,
  updatedDate,
  tags,
  series,
  seriesItems,
  minutesRead,
  heroImage,
  headings,
  prevPost,
  nextPost
} = Astro.props;

const seriesIndex = seriesItems?.findIndex(item => item.slug === slug);
---

<html lang="ko">
  <head>
    <BaseHead
      title={`${title} | ${SITE_NAME}`}
      description={description}
      image={heroImage}
      articleMeta={{
        publishedTime: pubDate.toISOString(),
        modifiedTime: updatedDate?.toISOString()
      }}
    />
  </head>
  <body>
    <a href="#main-content" class="skip-link" tabindex="0">본문으로 건너뛰기</a>
    <Header />

    <div class="shell" id="main-content" tabindex="-1">
      <article class="content-col">
        <header class="article-header">
          <PostMeta
            pubDate={pubDate}
            series={series}
            seriesIndex={seriesIndex !== undefined && seriesIndex >= 0 ? seriesIndex + 1 : undefined}
            minutesRead={minutesRead}
            tags={tags}
          />
          <h1 class="title">{title}</h1>
        </header>

        {seriesItems && seriesItems.length > 1 && (
          <SeriesNav title={series ?? ''} items={seriesItems} currentSlug={slug} />
        )}

        <div class="prose">
          <slot />
        </div>

        <footer class="footer-block">
          <PostFooter tags={tags} />
        </footer>

        {(prevPost || nextPost) && (
          <nav class="post-nav">
            {prevPost ? (
              <a href={`/posts/${prevPost.slug}/`} class="nav-item prev">
                <span class="label">이전 글</span>
                <span class="nav-title">{prevPost.title}</span>
              </a>
            ) : <span />}
            {nextPost && (
              <a href={`/posts/${nextPost.slug}/`} class="nav-item next">
                <span class="label">다음 글</span>
                <span class="nav-title">{nextPost.title}</span>
              </a>
            )}
          </nav>
        )}
      </article>

      <aside class="toc-col">
        <TableOfContents headings={headings} />
      </aside>
    </div>

    <Footer />

    <style>
      .shell {
        position: relative;
        max-width: 720px;
        margin: 0 auto;
        padding: 48px 24px 32px;
      }
      .toc-col {
        display: none;
      }
      @media (min-width: 1240px) {
        .toc-col {
          display: block;
          position: absolute;
          top: 48px;
          left: 100%;
          margin-left: 40px;
          width: 200px;
        }
      }

      .article-header {
        display: flex;
        flex-direction: column;
        gap: 20px;
        margin-bottom: 32px;
      }
      .title {
        font-family: var(--font-display);
        font-weight: 400;
        font-size: clamp(26px, 3.6vw, 36px);
        line-height: 1.4;
        color: var(--ink);
      }
      .content-col > * + * {
        margin-top: 32px;
      }

      .footer-block {
        padding-top: 32px;
        border-top: 1px solid var(--line);
      }

      .post-nav {
        display: flex;
        justify-content: space-between;
        gap: 24px;
        padding-top: 24px;
        border-top: 1px solid var(--line);
      }
      .nav-item {
        display: flex;
        flex-direction: column;
        gap: 6px;
        max-width: 48%;
        color: var(--ink);
        transition: opacity 0.2s;
      }
      .nav-item:hover {
        opacity: 0.6;
      }
      .nav-item.next {
        margin-left: auto;
        text-align: right;
      }
      .label {
        font-family: var(--font-mono);
        font-size: 10px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--ink-faint);
      }
      .nav-title {
        font-size: 14px;
        font-weight: 600;
      }

      @media (max-width: 640px) {
        .shell {
          padding: 32px 20px 24px;
        }
      }
    </style>
  </body>
</html>
