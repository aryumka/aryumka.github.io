---
import Social from '@/components/Social.astro';
---

<div class="bio">
  <img class="avatar" src="/images/about/avatar.jpeg" alt="Areum Yoo" />
  <div class="summary">
    <div class="name">Written by <a href="/about">Areum Yoo</a></div>
    <div class="role">Backend Developer</div>
    <div class="social">
      <Social />
    </div>
  </div>
</div>

<style>
  .bio {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 24px 0;
  }
  .avatar {
    width: 56px;
    height: 56px;
    flex-shrink: 0;
    border-radius: 50%;
    border: 1px solid var(--line-strong);
    object-fit: cover;
  }
  .summary {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .name {
    font-size: 14.5px;
    font-weight: 600;
    color: var(--ink);
  }
  .name a {
    text-decoration: underline;
    text-decoration-color: var(--line-strong);
    text-underline-offset: 3px;
  }
  .role {
    font-size: 12.5px;
    color: var(--ink-faint);
  }
  .social {
    margin-top: 6px;
  }
</style>
