---
interface ListItem {
  slug: string;
  title: string;
  pubDate: Date;
  series?: string;
  tags: string[];
}

interface Props {
  items: ListItem[];
}

const { items } = Astro.props;

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('ko-KR', { year: 'numeric', month: '2-digit', day: '2-digit' })
    .format(date)
    .replace(/\. /g, '.')
    .replace(/\.$/, '');
---

<div class="list">
  {items.map(item => (
    <a class="row" href={`/posts/${item.slug}/`}>
      <span class="date">{formatDate(item.pubDate)}</span>
      <span class="body">
        <span class="title">{item.title}</span>
        {(item.series || item.tags.length > 0) && (
          <span class="meta">
            {item.series && <span class="series">{item.series}</span>}
            {item.tags.map(tag => (
              <span class="tag">{tag.toUpperCase()}</span>
            ))}
          </span>
        )}
      </span>
    </a>
  ))}
</div>

<style>
  .list {
    border-top: 1px solid var(--line);
  }
  .row {
    display: flex;
    align-items: baseline;
    gap: 20px;
    padding: 16px 4px;
    border-bottom: 1px solid var(--line);
    color: var(--ink);
    transition: opacity 0.2s;
  }
  .row:hover {
    opacity: 0.6;
  }
  .date {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink-faint);
    flex-shrink: 0;
    width: 82px;
    font-variant-numeric: tabular-nums;
  }
  .body {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }
  .title {
    font-size: 14.5px;
    font-weight: 600;
    letter-spacing: -0.005em;
  }
  .meta {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .series {
    font-size: 11.5px;
    color: var(--ink-faint);
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.03em;
    color: var(--chip-ink);
    background: var(--chip-bg);
    padding: 3px 7px;
    border-radius: 3px;
  }

  @media (max-width: 640px) {
    .row {
      flex-wrap: wrap;
      gap: 4px 20px;
    }
  }
</style>
