---
import { getCollection, render } from 'astro:content';
import PostLayout from '@/layouts/PostLayout.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  const visiblePosts = [...allPosts]
    .filter(p => !p.data.draft && !p.data.hide)
    .sort((a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf());

  return allPosts.map(post => {
    const seriesSiblings = post.data.series
      ? allPosts
          .filter(p => p.data.series === post.data.series)
          .sort((a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf())
          .map(p => ({ slug: p.id, title: p.data.title }))
      : undefined;

    const idx = visiblePosts.findIndex(p => p.id === post.id);
    const prevPost = idx > 0 ? visiblePosts[idx - 1] : null;
    const nextPost = idx >= 0 && idx < visiblePosts.length - 1 ? visiblePosts[idx + 1] : null;

    return {
      params: { slug: post.id },
      props: { post, seriesSiblings, prevPost, nextPost }
    };
  });
}

const { post, seriesSiblings, prevPost, nextPost } = Astro.props;
const { Content, headings, remarkPluginFrontmatter } = await render(post);
---

<PostLayout
  slug={post.id}
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  tags={post.data.tags}
  series={post.data.series}
  seriesItems={seriesSiblings}
  minutesRead={remarkPluginFrontmatter.minutesRead}
  heroImage={post.data.heroImage}
  headings={headings}
  prevPost={prevPost ? { slug: prevPost.id, title: prevPost.data.title } : null}
  nextPost={nextPost ? { slug: nextPost.id, title: nextPost.data.title } : null}
>
  <Content />
</PostLayout>
