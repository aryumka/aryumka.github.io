---
import BaseLayout from '@/layouts/BaseLayout.astro';

const opensources = [
  { href: 'https://github.com/aryumka/kontainer', text: 'kontainer' },
  { href: 'https://github.com/aryumka/BigInteger.kt', text: 'BigInteger.kt' },
  { href: 'https://github.com/aryumka/tdd-practice', text: 'tdd-practice' },
  { href: 'https://github.com/aryumka/rabbitmq-tutorial', text: 'rabbitmq-tutorial' }
];
---

<BaseLayout title="About" description="About">
  <section class="page">
    <h1 class="page-title">About</h1>

    <div class="profile">
      <div class="name">Areum Yoo</div>
      <div class="role">Backend Developer</div>
    </div>

    <div class="block">
      <h2>💼 Currently working at</h2>
      <ul>
        <li><strong>삼쩜삼</strong> 2024. 09 ~</li>
      </ul>
    </div>

    <div class="block">
      <h2>❤️ Open Source</h2>
      <ul>
        {opensources.map(item => (
          <li>
            <a href={item.href} target="_blank" rel="noreferrer">{item.text}</a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <style>
    .page {
      max-width: 560px;
      margin: 0 auto;
      padding: 56px 24px 120px;
    }
    .page-title {
      font-family: var(--font-display);
      font-weight: 400;
      font-size: 30px;
      color: var(--ink);
      margin-bottom: 40px;
    }
    .profile {
      margin-bottom: 32px;
    }
    .profile .name {
      font-size: 18px;
      font-weight: 600;
      color: var(--ink);
    }
    .profile .role {
      font-size: 13.5px;
      color: var(--ink-faint);
      margin-top: 4px;
    }
    .block + .block {
      margin-top: 32px;
    }
    .block h2 {
      font-size: 15px;
      font-weight: 600;
      color: var(--ink);
      margin-bottom: 12px;
    }
    .block ul {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .block li {
      font-size: 14.5px;
      color: var(--ink-soft);
      line-height: 1.7;
    }
    .block strong {
      color: var(--ink);
      font-weight: 600;
    }
    .block a {
      color: var(--ink);
      text-decoration: underline;
      text-decoration-color: var(--line-strong);
      text-underline-offset: 3px;
      transition: text-decoration-color 0.2s;
    }
    .block a:hover {
      text-decoration-color: var(--ink);
    }

    @media (max-width: 640px) {
      .page {
        padding: 40px 20px 80px;
      }
    }
  </style>
</BaseLayout>
